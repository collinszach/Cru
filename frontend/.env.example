# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/cellar
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/cellar

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Map tiles (Protomaps PMTiles for production; demotiles fallback for dev)
# Production: host your own PMTiles file and point this at the .pmtiles URL
NEXT_PUBLIC_MAPTILES_URL=https://demotiles.maplibre.org/tiles/tiles.json
