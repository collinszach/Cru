# ============================================================
# Cru — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_HOST=cru-db
POSTGRES_PORT=5432
POSTGRES_DB=cru
POSTGRES_USER=cru
POSTGRES_PASSWORD=changeme

# Async SQLAlchemy connection string (used by FastAPI backend)
DATABASE_URL=postgresql+asyncpg://cru:changeme@cru-db:5432/cru

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://cru-redis:6379

# ------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ------------------------------------------------------------
MINIO_ENDPOINT=cru-minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET_LABELS=wine-labels
MINIO_SECURE=false

# ------------------------------------------------------------
# Clerk (Authentication)
# Server-side secret — never expose to the browser
# ------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------
# AI / ML APIs
# All AI calls go through the FastAPI backend — never frontend
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# ------------------------------------------------------------
# Application
# SECRET_KEY: minimum 32 chars, used for signing internal tokens
# ENVIRONMENT: development | production
# ------------------------------------------------------------
SECRET_KEY=changeme-32-chars-minimum-replace-this
ENVIRONMENT=development

# ------------------------------------------------------------
# Frontend (Next.js public env — exposed to the browser)
# NEXT_PUBLIC_* variables are safe for client-side use
# ------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_API_URL=http://localhost:8000
